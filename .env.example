# PostgreSQL Database Configuration
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=etl_password
POSTGRES_DB=etl_db

# Full database connection URL used by the orchestrator (SQLAlchemy format)
DATABASE_URL=postgresql://etl_user:etl_password@db:5432/etl_db

# URL for the mock API service (used by the orchestrator's API connector)
MOCK_API_URL=http://mock-api:8080